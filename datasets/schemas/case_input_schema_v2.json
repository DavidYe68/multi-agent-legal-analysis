{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/case_input_schema_v2.json",
  "title": "Multi-Agent Legal Deliberation Case Input v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id", "version", "language", "task_mode", "domain", "title",
    "source", "case_narrative", "participants", "facts", "claims",
    "evidence", "procedure", "role_views", "metadata"
  ],
  "properties": {
    "case_id": {"type": "string", "pattern": "^[a-z0-9_\\-]+$"},
    "version": {"type": "string", "const": "2.0"},
    "language": {"type": "string", "enum": ["zh-CN"]},
    "task_mode": {"type": "string", "enum": ["teaching", "practice"]},
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jurisdiction", "case_category", "primary_issue_type"],
      "properties": {
        "jurisdiction": {"type": "string"},
        "case_category": {"type": "string"},
        "primary_issue_type": {"type": "string"},
        "secondary_issue_types": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    },
    "title": {"type": "string", "minLength": 1},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_type", "citation", "url", "retrieval_date", "adaptation_type", "adaptation_notes", "anonymized"],
      "properties": {
        "source_id": {"type": "string"},
        "source_type": {"type": "string", "enum": ["public_judgment", "official_guiding_case", "teaching_case", "synthetic", "hybrid_adaptation", "legacy_demo"]},
        "citation": {"type": "string"},
        "url": {"type": "string"},
        "retrieval_date": {"type": "string"},
        "original_case_number": {"type": "string"},
        "adaptation_type": {"type": "string", "enum": ["none", "anonymized", "abridged", "fact_pattern_adaptation", "minimal_pair_construction", "synthetic_from_elements"]},
        "adaptation_notes": {"type": "string"},
        "anonymized": {"type": "boolean"}
      }
    },
    "case_narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["neutral_summary", "timeline"],
      "properties": {
        "neutral_summary": {"type": "string", "minLength": 1},
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["event_id", "order", "content", "fact_ids"],
            "properties": {
              "event_id": {"type": "string", "pattern": "^T[0-9]+$"},
              "order": {"type": "integer", "minimum": 1},
              "time_label": {"type": "string"},
              "content": {"type": "string"},
              "fact_ids": {"type": "array", "items": {"type": "string", "pattern": "^F[0-9]+$"}, "uniqueItems": true}
            }
          }
        }
      }
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["participant_id", "role", "anonymized_name"],
        "properties": {
          "participant_id": {"type": "string", "pattern": "^P[0-9]+$"},
          "role": {"type": "string", "enum": ["defendant", "victim", "witness", "co_defendant", "investigator", "expert", "other"]},
          "anonymized_name": {"type": "string"},
          "attributes": {"type": "object", "additionalProperties": {"type": ["string", "number", "boolean", "null"]}}
        }
      }
    },
    "facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fact_id", "content", "status", "asserted_by", "evidence_ids"],
        "properties": {
          "fact_id": {"type": "string", "pattern": "^F[0-9]+$"},
          "content": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["undisputed", "disputed", "alleged", "unknown"]},
          "asserted_by": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^E[0-9]+$"}, "uniqueItems": true},
          "notes": {"type": "string"}
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "actor_role", "content", "supporting_evidence_ids"],
        "properties": {
          "claim_id": {"type": "string", "pattern": "^C[0-9]+$"},
          "actor_role": {"type": "string", "enum": ["prosecution", "defense", "defendant", "victim", "witness", "other"]},
          "content": {"type": "string"},
          "supporting_evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^E[0-9]+$"}, "uniqueItems": true},
          "claim_status": {"type": "string", "enum": ["asserted", "admitted", "denied", "partly_admitted"]}
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "evidence_type", "content", "source_actor", "authenticity_status", "availability", "notes"],
        "properties": {
          "evidence_id": {"type": "string", "pattern": "^E[0-9]+$"},
          "evidence_type": {"type": "string", "enum": ["documentary", "electronic_data", "witness_testimony", "victim_statement", "defendant_statement", "co_defendant_statement", "expert_opinion", "inspection_record", "audio_visual", "physical_evidence", "other"]},
          "content": {"type": "string", "minLength": 1},
          "source_actor": {"type": "string"},
          "collection_context": {"type": "string"},
          "authenticity_status": {"type": "string", "enum": ["confirmed", "disputed", "unknown"]},
          "availability": {"type": "string", "enum": ["full", "partial", "summary_only", "missing"]},
          "notes": {"type": "string"}
        }
      }
    },
    "procedure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_stage", "completed_actions", "missing_or_disputed_actions", "evidence_examination"],
      "properties": {
        "current_stage": {"type": "string", "enum": ["case_analysis", "pretrial", "court_investigation", "court_debate", "deliberation", "unknown"]},
        "completed_actions": {"type": "array", "items": {"type": "string"}},
        "missing_or_disputed_actions": {"type": "array", "items": {"type": "string"}},
        "evidence_examination": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["evidence_id", "status"],
            "properties": {
              "evidence_id": {"type": "string", "pattern": "^E[0-9]+$"},
              "status": {"type": "string", "enum": ["examined", "not_examined", "disputed", "unknown"]},
              "notes": {"type": "string"}
            }
          }
        }
      }
    },
    "role_views": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clerk", "issue_spotter", "prosecutor", "defense_lawyer", "defendant", "judge", "reviewers", "foreperson", "writer"],
      "properties": {
        "clerk": {"$ref": "#/$defs/roleView"},
        "issue_spotter": {"$ref": "#/$defs/roleView"},
        "prosecutor": {"$ref": "#/$defs/roleView"},
        "defense_lawyer": {"$ref": "#/$defs/roleView"},
        "defendant": {"$ref": "#/$defs/roleView"},
        "judge": {"$ref": "#/$defs/roleView"},
        "reviewers": {"$ref": "#/$defs/roleView"},
        "foreperson": {"$ref": "#/$defs/roleView"},
        "writer": {"$ref": "#/$defs/roleView"}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["difficulty", "paired_case_id", "pair_variant", "target_capabilities", "created_by", "review_status"],
      "properties": {
        "difficulty": {"type": "string", "enum": ["easy", "medium", "hard"]},
        "paired_case_id": {"type": ["string", "null"]},
        "pair_variant": {"type": ["string", "null"], "enum": ["A", "B", null]},
        "target_capabilities": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "created_by": {"type": "array", "items": {"type": "string"}},
        "review_status": {"type": "string", "enum": ["draft", "legal_reviewed", "second_reviewed", "final"]}
      }
    }
  },
  "$defs": {
    "roleView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fact_ids", "claim_ids", "evidence_ids", "procedure_access", "notes"],
      "properties": {
        "fact_ids": {"type": "array", "items": {"type": "string", "pattern": "^F[0-9]+$"}, "uniqueItems": true},
        "claim_ids": {"type": "array", "items": {"type": "string", "pattern": "^C[0-9]+$"}, "uniqueItems": true},
        "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^E[0-9]+$"}, "uniqueItems": true},
        "procedure_access": {"type": "boolean"},
        "notes": {"type": "string"}
      }
    }
  }
}
